{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/hero.png", "dest": "/public/hero.png" },
    { "src": "/blog", "dest": "/public/blog.html" },
    { "src": "/blog/american-bully-vs-exotic-bully", "dest": "/public/blog-american-bully-vs-exotic-bully.html" },
    { "src": "/blog/abkc-show-classes-explained", "dest": "/public/blog-abkc-show-classes-explained.html" },
    { "src": "/blog/what-judges-look-for", "dest": "/public/blog-what-judges-look-for.html" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/logo.png", "dest": "/public/logo.png" },
    { "src": "/hero.png", "dest": "/public/hero.png" },
    { "src": "/john1.jpg.jpeg", "dest": "/public/john1.jpg.jpeg" },
    { "src": "/john2.jpg.jpeg", "dest": "/public/john2.jpg.jpeg" },
    { "src": "/john3.jpg.jpeg", "dest": "/public/john3.jpg.jpeg" },
    { "src": "/calculator.html", "dest": "/public/calculator.html" },
    { "src": "/app", "dest": "/public/app.html" },
    { "src": "/app.html", "dest": "/public/app.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
